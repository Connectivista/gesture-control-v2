{
  "name": "gesturecontrol",
  "version": "1.0.0",
  "description": "Control music with hand gestures",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win"
  },
  "author": "GestureControl",
  "license": "ISC",
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "app.gesturecontrol",
    "productName": "GestureControl",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "sign": false,
      "notarize": false
    },
    "win": {
      "target": "nsis"
    }
  }
}
